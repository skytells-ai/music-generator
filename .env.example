# Optional: show the layout debug toolbar (orchestrator / player / rail / tools) in production.
# In development it is shown automatically. Uncomment to enable on deployed builds.
# NEXT_PUBLIC_DEBUG_UI=1

# Server-only Skytells API key for `app/api/generate/route.ts`
# ALWAYS set this API key on server side.
# GET YOUR API KEY FROM https://skytells.ai/dashboard/api-keys
# OR FROM: https://console.skytells.ai/settings/api-keys
SKYTELLS_API_KEY=


# IMAGE GENERATION MODEL
# Available models can be found at https://skytells.ai/explore/models
# Default model is "truefusion"
# See: https://learn.skytells.ai/docs/api/v1/models/catalog
SKYTELLS_IMAGE_GENERATION_MODEL="truefusion"

# LYRICS GENERATION MODEL
# Available models can be found at https://skytells.ai/explore/models
# Default model is "deepbrain-router"
# See: https://learn.skytells.ai/docs/api/v1/models/catalog
# This model uses Skytells Chat API.
# Doc: https://learn.skytells.ai/docs/sdks/ts/chat
SKYTELLS_LYRICS_GENERATION_MODEL="deepbrain-router"



# ENABLE DEBUG UI IN DEVELOPMENT
NEXT_PUBLIC_DEBUG_UI=false
